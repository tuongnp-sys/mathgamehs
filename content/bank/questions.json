      "status": "approved",
      "context": {
        "en": "Given $f(x) = x^3 - 3x + 1$.",
        "vi": "Cho $f(x) = x^3 - 3x + 1$."
      },
      "stem": {
        "en": "Consider the following statements:",
        "vi": "Xét các mệnh đề sau:"
      },
      "subItems": [
        {
          "label": "a",
          "statement": {
            "en": "$f'(x) = 3x^2 - 3$.",
            "vi": "Mệnh đề $f'(x) = 3x^2 - 3$."
          },
          "isTrue": true,
          "explanation": {
            "en": "Direct differentiation.",
            "vi": "Đạo hàm trực tiếp."
          }
        },
        {
          "label": "b",
          "statement": {
            "en": "$f$ has two critical points.",
            "vi": "Hàm số $f$ có hai điểm cực trị."
          },
          "isTrue": true,
          "explanation": {
            "en": "$f'(x)=0 \\Leftrightarrow x = \\pm 1$.",
            "vi": "$f'(x)=0 \\Leftrightarrow x = \\pm 1$."
          }
        },
        {
          "label": "c",
          "statement": {
            "en": "$f$ is increasing on $(1,+\\infty)$.",
            "vi": "Hàm số $f$ đồng biến trên $(1,+\\infty)$."
          },
          "isTrue": true,
          "explanation": {
            "en": "$f'(x) > 0$ for $x > 1$.",
            "vi": "$f'(x) > 0$ khi $x > 1$."
          }
        },
        {
          "label": "d",
          "statement": {
            "en": "The maximum value of $f$ on $\\mathbb{R}$ is $3$.",
            "vi": "Giá trị lớn nhất của $f$ trên $\\mathbb{R}$ bằng $3$."
          },
          "isTrue": false,
          "explanation": {
            "en": "$f$ has no global maximum on $\\mathbb{R}$.",
            "vi": "$f$ không có giá trị lớn nhất trên $\\mathbb{R}$."
          }
        }
      ]
    },
