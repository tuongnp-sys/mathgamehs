    {
      "id": "off25-0101-q01",
      "part": 1,
      "order": 1,
      "source": "official-thpt-2025-0101",
      "status": "approved",
      "stem": {
        "vi": "Cho hình lăng trụ $ABC.A'B'C'$. Phát biểu nào sau đây là đúng?",
        "en": "Given triangular prism $ABC.A'B'C'$. Which statement is correct?"
      },
      "options": [
        {
          "label": "A",
          "text": {
            "vi": "$\\overrightarrow{BA}+\\overrightarrow{A'C'}=\\overrightarrow{BC'}$",
            "en": "$\\overrightarrow{BA}+\\overrightarrow{A'C'}=\\overrightarrow{BC'}$"
          },
          "correct": false
        },
        {
          "label": "B",
          "text": {
            "vi": "$\\overrightarrow{BA}+\\overrightarrow{A'C'}=\\overrightarrow{C'B'}$",
            "en": "$\\overrightarrow{BA}+\\overrightarrow{A'C'}=\\overrightarrow{C'B'}$"
          },
          "correct": false
        },
        {
          "label": "C",
          "text": {
            "vi": "$\\overrightarrow{BA}+\\overrightarrow{A'C'}=\\overrightarrow{BC}$",
            "en": "$\\overrightarrow{BA}+\\overrightarrow{A'C'}=\\overrightarrow{BC}$"
          },
          "correct": true
        },
        {
          "label": "D",
          "text": {
            "vi": "$\\overrightarrow{BA}+\\overrightarrow{A'C'}=\\overrightarrow{A'A}$",
            "en": "$\\overrightarrow{BA}+\\overrightarrow{A'C'}=\\overrightarrow{A'A}$"
          },
          "correct": false
        }
      ],
      "explanation": {
        "vi": "Quy tắc hình hộp: $\\overrightarrow{BA}+\\overrightarrow{A'C'}=\\overrightarrow{BC}$.",
        "en": "Vector addition in the prism gives $\\overrightarrow{BA}+\\overrightarrow{A'C'}=\\overrightarrow{BC}$."
      },
      "examFigure": "/assets/exams/2025-de-dapan/figures/off25-0101-q01.png"
    },
